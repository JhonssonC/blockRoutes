<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron para Importar Bloqueos desde Excel Diariamente -->
        <record id="ir_cron_import_excel_blocked_routes" model="ir.cron">
            <field name="name">Block Routes: Importar bloqueos desde Excel</field>
            <field name="model_id" ref="blockRoutes.model_block_routes_blocked"/>
            <field name="state">code</field>
            <field name="code">model.cron_import_excel_blocked_routes()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron para Importar Geometrías desde Shapefiles Diariamente -->
        <record id="ir_cron_import_shapes_to_routes" model="ir.cron">
            <field name="name">Block Routes: Sincronizar mapas desde Shapefile</field>
            <field name="model_id" ref="blockRoutes.model_block_routes_blocked"/>
            <field name="state">code</field>
            <field name="code">model.cron_import_shapes_to_routes()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
