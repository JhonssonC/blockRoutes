<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_blocked_route_import_wizard_form" model="ir.ui.view">
        <field name="name">block_routes.blocked_import_wizard.form</field>
        <field name="model">block_routes.blocked_import_wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Bloqueos desde Excel">
                <sheet>
                    <group>
                        <field name="filename" invisible="1"/>
                        <field name="excel_file" filename="filename" widget="binary" string="Archivo Excel (.xlsx)"/>
                    </group>
                    <p class="text-muted">
                        El archivo Excel debe contener 4 columnas con el siguiente orden exacto y empezar desde la fila 2 (la fila 1 es la cabecera):<br/>
                        <strong>Columna 1:</strong> Identificador de la Ruta (ej: 010101)<br/>
                        <strong>Columna 2:</strong> Motivo del Bloqueo<br/>
                        <strong>Columna 3:</strong> Fecha y Hora de Inicio (AAAA-MM-DD HH:MM:SS)<br/>
                        <strong>Columna 4:</strong> Fecha y Hora de Fin (AAAA-MM-DD HH:MM:SS)
                    </p>
                </sheet>
                <footer>
                    <button name="action_import_excel" string="Importar" type="object" class="btn-primary" icon="fa-upload"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_block_routes_blocked_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Bloqueos desde Excel</field>
        <field name="res_model">block_routes.blocked_import_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
